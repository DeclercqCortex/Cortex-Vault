{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cortex",
  "version": "0.1.0",
  "identifier": "com.declercq.cortex",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cortex",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first research notebook for cancer engineering.",
    "longDescription": "Cortex is a single-user, local-first markdown research notebook with a fast file tree, TipTap editor, full-text search, wikilinks, backlinks, and git auto-commit. Notes live as plain markdown on disk. No cloud, no account.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
